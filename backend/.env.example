# Comma-separated list of additional allowed CORS origins.
# Example: CORS_ORIGINS=http://127.0.0.1:8081,http://192.168.1.50:8081
CORS_ORIGINS=

# Set to false to disable ngrok wildcard origin.
CORS_ALLOW_NGROK=true

# ── Blockchain (Sepolia Testnet) ──────────────────────────────────────────────
# Alchemy / Infura / any Sepolia JSON-RPC endpoint
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Backend wallet private key (MetaMask → Account Details → Export Private Key)
# NEVER commit the real value. NEVER log it.
BLOCKCHAIN_WALLET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Deployed AttendanceLedger contract address (filled in after `npm run deploy:sepolia`)
CONTRACT_ADDRESS=0xYOUR_CONTRACT_ADDRESS_HERE
